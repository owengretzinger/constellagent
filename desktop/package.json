{
  "name": "constellagent",
  "productName": "Constellagent",
  "version": "1.0.0",
  "description": "Mac app for running multiple AI agents in parallel",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:renderer\" \"LD_LIBRARY_PATH=$PWD/build/dev-linux-x64/Constellagent-dev/bin:$PWD/node_modules/electrobun/dist-linux-x64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH} ELECTROBUN_RENDERER_URL=http://127.0.0.1:5173 electrobun dev --watch\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "build:renderer": "vite build",
    "build": "bun run build:renderer && electrobun build",
    "preview": "LD_LIBRARY_PATH=$PWD/build/dev-linux-x64/Constellagent-dev/bin:$PWD/node_modules/electrobun/dist-linux-x64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH} electrobun run",
    "test": "bunx tsc --noEmit",
    "rebuild": "echo 'No rebuild step required for Electrobun'",
    "dist": "bun run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@pierre/diffs": "^1.0.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "monaco-editor": "^0.55.1",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electrobun": "^1.14.4",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
