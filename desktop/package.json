{
  "name": "constellagent",
  "productName": "Constellagent",
  "version": "1.0.0",
  "description": "Mac app for running multiple AI agents in parallel",
  "type": "module",
  "scripts": {
    "start": "vite build && LD_LIBRARY_PATH=\"$PWD/build/dev-linux-x64/Constellagent-dev/bin:${LD_LIBRARY_PATH:-}\" electrobun dev",
    "dev": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build --env=canary",
    "build:stable": "vite build && electrobun build --env=stable",
    "test": "bunx playwright test --project=desktop",
    "rebuild": "echo \"No native rebuild step required with Electrobun\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@pierre/diffs": "^1.0.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "electrobun": "^1.14.4",
    "monaco-editor": "^0.55.1",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.3",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.5"
  }
}
