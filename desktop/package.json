{
  "name": "constellagent",
  "productName": "Constellagent",
  "version": "1.0.0",
  "description": "Desktop app for running multiple AI agents in parallel",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build",
    "test": "bunx playwright test --project=electron"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@pierre/diffs": "^1.0.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "electrobun": "latest",
    "monaco-editor": "^0.55.1",
    "node-cron": "^4.2.1",
    "react": "^19.2.4",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.3"
  }
}
